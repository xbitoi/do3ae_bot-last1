# ============================================================
# Telegram Bot Studio — Environment Configurations
# Copy this file to '.env' and modify the values
# ============================================================

# The port the server runs on (default: 3000)
PORT=3000

# The execution environment
NODE_ENV=production

# ─── Proxy (Optional) ───────────────────────────────────
# If you need a proxy to access Telegram or Gemini APIs:
# HTTPS_PROXY=http://user:password@proxy-host:port
# HTTP_PROXY=http://user:password@proxy-host:port
# SOCKS5_PROXY=socks5://user:password@proxy-host:port
# ALL_PROXY=http://proxy-host:port
